# ===========================================
# Variables de entorno del Backend
# Copiar este archivo como .env y completar
# cp .env.example .env
# ===========================================

# Base de datos MySQL (requerido)
DB_URL=mysql://usuario:contraseña@localhost:3306/VuelosApp

# TLS/SSL para proveedores cloud (TiDB, PlanetScale, etc.)
# En producción suele ser necesario mantener DB_SSL=true
DB_SSL=true
# Cambiar a false solo si usás certificados propios/no confiables en desarrollo
DB_SSL_REJECT_UNAUTHORIZED=true
# Opcional: certificado CA en una sola línea, escapando saltos como \n
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# Clave secreta para firmar tokens JWT (requerido)
TOKEN_SECRET=cambiar_por_una_clave_secreta_segura

# Entorno de ejecución (development | production)
NODE_ENV=development

# Orígenes permitidos por CORS (separados por coma)
FRONTEND_ORIGINS=http://localhost:5173

# Mercado Pago (requerido solo para pagos)
MP_ACCESS_TOKEN=TEST-tu-access-token-de-mercadopago
MP_CURRENCY=ARS

# URLs públicas (requerido solo para pagos en producción)
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:3000
